# Snowflake SPCS Image Push Configuration
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit credentials.
#
# To find your repository URL:
#   Run SHOW IMAGE REPOSITORIES in Snowsight after deploy_all.sql creates
#   the GLAZE_IMAGE_REPO, then copy the repository_url column value.
#
# To generate a PAT:
#   Snowsight → User menu → Programmatic Access Tokens → Generate

export SNOWFLAKE_IMAGE_REPO_URL="orgname-acctname.registry.snowflakecomputing.com/snowflake_example/glaze_and_classify/glaze_image_repo"
export SNOWFLAKE_USERNAME="your-snowflake-username"
export SNOWFLAKE_REGISTRY_PAT="your-pat-here"

# 1Password CLI integration (optional):
# export SNOWFLAKE_REGISTRY_PAT=$(op read "op://vault-name/Snowflake Registry PAT/credential")
